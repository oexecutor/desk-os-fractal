{
  "name": "desk-os-fractal",
  "private": true,
  "version": "1.1.0",
  "description": "DESK-OS / TAL de Fractal — modular monolith TypeScript, web-first.",
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* --filter=./apps/* run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "pnpm -r --filter=./packages/* --filter=./apps/* run typecheck",
    "validate": "pnpm run validate:contracts && pnpm run typecheck && pnpm run lint",
    "validate:contracts": "tsx scripts/validate-contracts.ts",
    "dev:web": "pnpm --filter @desk-os/web dev",
    "e2e": "playwright test",
    "release:zip": "tsx scripts/build-release-zip.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.1",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "typescript-eslint": "8.64.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "archiver": "8.0.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "js-yaml": "5.2.1",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
