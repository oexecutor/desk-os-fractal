{
  "name": "@desk-os/client-sdk",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Typed fetch client for the DESK-OS HTTP API.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@desk-os/domain": "workspace:*"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
