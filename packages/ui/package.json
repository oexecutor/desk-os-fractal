{
  "name": "@desk-os/ui",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Accessible, low-density fractal UI components and design tokens.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@desk-os/domain": "workspace:*",
    "react": "19.2.7"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "@types/react": "19.2.17",
    "react-dom": "19.2.7",
    "@testing-library/react": "16.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/user-event": "14.6.1",
    "jsdom": "29.1.1"
  }
}
