{
  "name": "@desk-os/storage",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Repository interfaces plus memory and Netlify Blobs adapters.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@desk-os/domain": "workspace:*",
    "@desk-os/schemas": "workspace:*",
    "@desk-os/events": "workspace:*",
    "@netlify/blobs": "10.7.9"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "@types/node": "22.20.1"
  }
}
