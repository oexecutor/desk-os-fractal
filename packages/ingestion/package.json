{
  "name": "@desk-os/ingestion",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Upload/text intake pipeline: SourceArtifact, extractors, ExtractedDocument.",
  "main": "./dist/index.js",
