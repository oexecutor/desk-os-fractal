{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://desk-os.app/schemas/print-snapshot.schema.json",
  "title": "WeeklyFoldedPrintSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "workspace_id",
    "plan_version_id",
    "sprint_id",
    "created_at",
    "checksum",
    "format",
    "layout",
    "face1",
    "face2"
  ],
  "properties": {
    "schema_version": { "const": "1.1.0" },
    "id": { "type": "string", "minLength": 16 },
    "workspace_id": { "type": "string", "minLength": 16 },
    "plan_version_id": { "type": "string", "minLength": 16 },
    "sprint_id": { "type": "string", "minLength": 16 },
    "state_version_at_emission": { "type": ["integer", "null"], "minimum": 0 },
    "created_at": { "type": "string", "format": "date-time" },
    "checksum": { "type": "string", "pattern": "^[A-F0-9-]{8,64}$" },
    "format": { "const": "A4_PORTRAIT_FOLDED_WEEKLY_V2" },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sheet", "zones_mm", "face2_rotation_deg", "print_sides", "scale_percent", "safe_margin_mm"],
      "properties": {
        "sheet": { "const": "A4_PORTRAIT_210X297_MM" },
        "zones_mm": {
          "type": "object",
          "additionalProperties": false,
          "required": ["top_mechanical", "face1", "middle_mechanical", "face2", "bottom_mechanical"],
          "properties": {
            "top_mechanical": { "const": 40 },
            "face1": { "const": 100 },
            "middle_mechanical": { "const": 40 },
            "face2": { "const": 100 },
            "bottom_mechanical": { "const": 17 }
          }
        },
        "face2_rotation_deg": { "const": 180 },
        "print_sides": { "const": "SINGLE_SIDED" },
        "scale_percent": { "const": 100 },
        "safe_margin_mm": { "type": "number", "minimum": 5 }
      }
    },
    "face1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "user_label",
        "context_trail",
        "week_label",
        "date_range",
        "dominant_result",
        "definition_of_done",
        "weekly_contract",
        "blocks",
        "known_risks",
        "qr_token_id"
      ],
      "properties": {
        "user_label": { "type": "string", "minLength": 1 },
        "context_trail": { "type": "array", "minItems": 1, "maxItems": 4, "items": { "type": "string", "minLength": 1 } },
        "week_label": { "type": "string", "minLength": 1 },
        "date_range": { "type": "string", "minLength": 1 },
        "dominant_result": { "type": "string", "minLength": 1, "maxLength": 110 },
        "definition_of_done": { "type": "string", "minLength": 1, "maxLength": 150 },
        "weekly_contract": {
          "type": "object",
          "additionalProperties": false,
          "required": ["blocks", "actions", "syntheses"],
          "properties": {
            "blocks": { "const": 5 },
            "actions": { "const": 15 },
            "syntheses": { "const": 5 }
          }
        },
        "blocks": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["day_label", "title", "synthesis_title"],
            "properties": {
              "day_label": { "enum": ["SEG", "TER", "QUA", "QUI", "SEX"] },
              "title": { "type": "string", "minLength": 1, "maxLength": 42 },
              "synthesis_title": { "type": "string", "minLength": 1, "maxLength": 48 }
            }
          }
        },
        "known_risks": { "type": "array", "maxItems": 3, "items": { "type": "string", "minLength": 1, "maxLength": 120 } },
        "qr_token_id": { "type": "string", "minLength": 16 }
      }
    },
    "face2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_label", "week_label", "days", "recycle_options", "closeout_fields", "qr_token_id"],
      "properties": {
        "project_label": { "type": "string", "minLength": 1 },
        "week_label": { "type": "string", "minLength": 1 },
        "days": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["day_label", "block_title", "actions", "synthesis"],
            "properties": {
              "day_label": { "enum": ["SEG", "TER", "QUA", "QUI", "SEX"] },
              "block_title": { "type": "string", "minLength": 1, "maxLength": 42 },
              "method_tag": { "type": ["string", "null"], "maxLength": 30 },
              "actions": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id", "title", "done_criteria"],
                  "properties": {
                    "id": { "type": "string", "minLength": 16 },
                    "title": { "type": "string", "minLength": 1, "maxLength": 38 },
                    "done_criteria": { "type": "string", "minLength": 1 }
                  }
                }
              },
              "synthesis": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "title", "completion_rule"],
                "properties": {
                  "id": { "type": "string", "minLength": 16 },
                  "title": { "type": "string", "minLength": 1, "maxLength": 48 },
                  "completion_rule": { "const": "ALL_THREE_ACTIONS_DONE" }
                }
              }
            }
          }
        },
        "recycle_options": {
          "const": ["CONTINUE", "REDUCE", "SPLIT", "RECONFIGURE"]
        },
        "closeout_fields": {
          "const": ["MAIN_DELIVERY", "BLOCKER", "NEXT_ACTION"]
        },
        "qr_token_id": { "type": "string", "minLength": 16 }
      }
    }
  }
}
