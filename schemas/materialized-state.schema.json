{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://desk-os.app/schemas/materialized-state.schema.json",
  "title": "MaterializedState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workspace_id",
    "plan_version_id",
    "stream_version",
    "node_states",
    "focused_node_id",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 16
    },
    "plan_version_id": {
      "type": "string",
      "minLength": 16
    },
    "stream_version": {
      "type": "integer",
      "minimum": 0
    },
    "node_states": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "status",
          "updated_at"
        ],
        "properties": {
          "status": {
            "enum": [
              "TODO",
              "IN_PROGRESS",
              "BLOCKED",
              "DONE",
              "CANCELLED"
            ]
          },
          "started_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "completed_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "blocked_reason": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence_count": {
            "type": "integer",
            "minimum": 0
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "focused_node_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
