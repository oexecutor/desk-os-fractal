{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://desk-os.app/schemas/plan-version.schema.json",
  "title": "PlanVersion",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "workspace_id",
    "version",
    "lifecycle_state",
    "root_node_ids",
    "nodes",
    "validation_report",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "minLength": 16
    },
    "workspace_id": {
      "type": "string",
      "minLength": 16
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "lifecycle_state": {
      "enum": [
        "GENERATED",
        "IN_REVIEW",
        "APPROVED",
        "ACTIVE",
        "BLOCKED",
        "REJECTED",
        "SUPERSEDED",
        "COMPLETED",
        "ARCHIVED"
      ]
    },
    "input_kind": {
      "enum": [
        "single_project",
        "portfolio",
        "indeterminate"
      ]
    },
    "objective": {
      "type": "string",
      "maxLength": 4000
    },
    "dominant_result": {
      "type": "string",
      "maxLength": 500
    },
    "root_node_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 16
      },
      "uniqueItems": true
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "work-node.schema.json"
      }
    },
    "validation_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "valid",
        "errors",
        "warnings",
        "gaps"
      ],
      "properties": {
        "valid": {
          "type": "boolean"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "source_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 16
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string"
    },
    "approved_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "approved_by": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
