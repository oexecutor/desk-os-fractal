{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://desk-os.app/schemas/extracted-document.schema.json",
  "title": "ExtractedDocument",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "workspace_id",
    "source_artifact_id",
    "blocks",
    "warnings",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "minLength": 16
    },
    "workspace_id": {
      "type": "string",
      "minLength": 16
    },
    "source_artifact_id": {
      "type": "string",
      "minLength": 16
    },
    "language": {
      "type": [
        "string",
        "null"
      ]
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "locator",
          "text"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 8
          },
          "kind": {
            "enum": [
              "paragraph",
              "heading",
              "table",
              "list",
              "metadata"
            ]
          },
          "locator": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "data": {
            "type": [
              "object",
              "array",
              "null"
            ]
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
