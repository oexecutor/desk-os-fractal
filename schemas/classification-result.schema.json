{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://desk-os.app/schemas/classification-result.schema.json",
  "title": "ClassificationResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "confidence",
    "evidence_refs",
    "gaps"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "kind": {
      "enum": [
        "single_project",
        "portfolio",
        "indeterminate"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_artifact_id",
          "locator"
        ],
        "properties": {
          "source_artifact_id": {
            "type": "string"
          },
          "locator": {
            "type": "string"
          }
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
