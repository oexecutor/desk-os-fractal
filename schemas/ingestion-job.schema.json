{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://desk-os.app/schemas/ingestion-job.schema.json",
  "title": "IngestionJob",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "workspace_id",
    "status",
    "source_artifact_ids",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "minLength": 16
    },
    "workspace_id": {
      "type": "string",
      "minLength": 16
    },
    "status": {
      "enum": [
        "UPLOADED",
        "EXTRACTING",
        "EXTRACTED",
        "CLASSIFYING",
        "DECOMPOSING",
        "VALIDATING",
        "COMPLETED",
        "BLOCKED",
        "FAILED",
        "CANCELLED"
      ]
    },
    "source_artifact_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 16
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "enum": [
              "PENDING",
              "RUNNING",
              "DONE",
              "FAILED"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "result_plan_version_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "error_code": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
